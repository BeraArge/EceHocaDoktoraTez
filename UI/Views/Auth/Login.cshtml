@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Options
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Mvc;
@* @inject IOptions<GoogleCaptchaConfig> GoogleCaptchaConfig *@
@inject IAntiforgery antiforgery
@{
    ViewBag.Title = "Sign In";

    Layout = null;

    var request_token = antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<style>
    #recaptcha-error {
        color: red;
        margin-top: 10px;
        display: none; /* Başlangıçta gizli */
    }

    .auth-bg-cover {
        background: linear-gradient(-45deg, #78bb70 40%, #186481) !important;
    }
</style>


<!doctype html>
<html lang="en">
<head>
    @Html.Partial("~/Views/Shared/_head_css.cshtml")
</head>
<body>

    <div class="auth-page-wrapper auth-bg-cover py-5 d-flex justify-content-center align-items-center min-vh-100">


        <div class="auth-page-content overflow-hidden pt-lg-5">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card overflow-hidden" style="border-radius:20px ">
                            <div class="row g-0">
                                <div class="col-lg-6">
                                    <div class="p-lg-5 p-4 h-100 d-flex justify-content-center align-items-center">
                                        <img src="~/logo/logo_1.png" style="height:250px" />
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="p-lg-5 p-4">
                                        <div>
                                            <h5 class="text-primary">Yönetim Paneli</h5>
                                            <p class="text-muted">Hoşgeldiniz.</p>
                                        </div>

                                        <div class="mt-4">
                                            <form id="login-form">
                                                <input type="hidden" id="UserLoginDTOToken" name="Token" />
                                                <div class="mb-3">
                                                    <label class="form-label">Telefon Numarası</label>
                                                    <input type="text" class="form-control" required minlength="4" maxlength="100" name="Phone" placeholder="Phone" max="10">
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Şifre</label>
                                                    <div class="position-relative auth-pass-inputgroup mb-3">
                                                        <input type="password" class="form-control password-input" name="Password" minlength="4" maxlength="100" placeholder="Şifre" id="password-input">
                                                        <button class="btn btn-link position-absolute end-0 top-0 text-decoration-none text-muted password-addon" type="button" id="password-addon"><i class="ri-eye-fill align-middle"></i></button>
                                                    </div>


                                                </div>

                                                <div class="col-12">
                                                    <div class="mb-4 float-end">
                                                        <span>
                                                            <i class="ri-lock-password-fill align-middle"></i><a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal">
                                                                Şifremi Unuttum
                                                            </a>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-12">
                                                    <div class="mb-3">
                                                        <div style="display: none;" class="alert alert-danger alert-dismissible" id="errors-block"></div>
                                                    </div>
                                                </div>
                                                <button type="submit" class="btn  w-100" style="background-color: #78bb70;">
                                                    Giriş Yap
                                                </button>

                                            </form>
                                        </div>


                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <footer class="footer">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="text-center">
                            <p class="mb-0" style="color:black">
                                &copy;
                                <script>document.write(new Date().getFullYear())</script>  Bera Yazılım. Tüm Hakları Saklıdır
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
        <!-- end Footer -->
        <div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:15px;">
                    <div class="modal-header">
                        <h5 class="modal-title">Şifremi Unuttum</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Telefon Numarası</label>
                            <input type="text"
                                   id="forgotPhone"
                                   class="form-control"
                                   placeholder="5XXXXXXXXX"
                                   maxlength="10" />
                            <small class="text-muted">Başında 0 olmadan 10 haneli telefon giriniz.</small>
                        </div>

                        <div id="forgotSmsError" class="alert alert-danger d-none"></div>
                        <div id="forgotSmsSuccess" class="alert alert-success d-none">
                            SMS başarıyla gönderildi.
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Kapat</button>
                        <button type="button" id="sendSmsBtn" class="btn" style="background-color:#78bb70;">
                            SMS Gönder
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script type="text/javascript">
        const VerifyToken = "@request_token";
    </script>

    @Html.Partial("~/Views/Shared/_vendor_scripts.cshtml")
    <script src="~/page-js/auth/login.js"></script>
    <script src="~/assets/libs/particles.js/particles.js"></script>
    <script src="~/assets/js/pages/particles.app.js"></script>
    <script src="~/js/global_libraries/jquery.min.js"></script>
    <script src="~/assets/js/pages/password-addon.init.js"></script>
    <script src="~/theme/velzon/assets/js/app.js"></script>
    <script src="~/theme/velzon/assets/js/pages/password-addon.init.js"></script>
    <script>
        $("#forgotPhone").on("input", function () {
            this.value = this.value.replace(/\D/g, "").slice(0, 10);
        });

        $("#sendSmsBtn").on("click", function () {
            const phone = $("#forgotPhone").val();

            $("#forgotSmsError").addClass("d-none").text("");
            $("#forgotSmsSuccess").addClass("d-none");

            const phoneRegex = /^5\d{9}$/;

            if (!phoneRegex.test(phone)) {
                $("#forgotSmsError")
                    .removeClass("d-none")
                    .text("Lütfen başında 0 olmadan geçerli bir telefon numarası giriniz. Örn: 5XXXXXXXXX");
                return;
            }

            $.ajax({
                url: "/User/SendSms",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    phone: phone
                }),
                success: function () {
                    $("#forgotSmsSuccess").removeClass("d-none");
                    $("#forgotPhone").val("");
                },
                error: function (xhr) {
                    let message = "SMS gönderilirken bir hata oluştu.";

                    if (xhr.responseText) {
                        message = xhr.responseText;
                    }

                    $("#forgotSmsError")
                        .removeClass("d-none")
                        .text(message);
                }
            });
        });
    </script>
    @section Scripts {
    }
</body>
</html>
