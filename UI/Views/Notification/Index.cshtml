@{
    ViewData["Title"] = "Bildirimler";
}

<style>
    :root {
        --lg-primary: #087c8f;
        --lg-secondary: #6fbd63;
        --lg-soft: #eef9f5;
        --lg-dark: #2f3a4a;
        --lg-muted: #8b95a7;
    }

    .lymph-page {
        min-height: calc(100vh - 140px);
    }

    .lymph-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 32px;
        margin-bottom: 28px;
        background: linear-gradient(135deg, #087c8f 0%, #28a49a 48%, #6fbd63 100%);
        color: #fff;
        box-shadow: 0 18px 45px rgba(8, 124, 143, .22);
    }

    .hero-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .hero-subtitle {
        opacity: .92;
        max-width: 650px;
        margin-bottom: 0;
    }

    .hero-logo-mark {
        width: 86px;
        height: 86px;
        border-radius: 24px;
        background: rgba(255, 255, 255, .95);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 30px rgba(0, 0, 0, .12);
    }

        .hero-logo-mark img {
            width: 68px;
            height: 68px;
            object-fit: contain;
        }

    .lg-card {
        border: 0;
        border-radius: 26px;
        background: rgba(255, 255, 255, .92);
        box-shadow: 0 14px 35px rgba(31, 45, 61, .08);
    }

    .lg-card-header {
        padding: 24px 26px 0;
    }

    .lg-card-body {
        padding: 24px 26px 26px;
    }

    .section-title {
        color: var(--lg-dark);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .section-desc {
        color: var(--lg-muted);
        font-size: 14px;
        margin-bottom: 0;
    }

    .lg-input {
        border-radius: 16px;
        border: 1px solid #e4eaf1;
        padding: 12px 15px;
        background-color: #fbfdff;
    }

        .lg-input:focus {
            border-color: var(--lg-primary);
            box-shadow: 0 0 0 .18rem rgba(8, 124, 143, .12);
        }

    .btn-lymph {
        border: 0;
        border-radius: 999px;
        padding: 11px 24px;
        color: #fff;
        font-weight: 600;
        background: linear-gradient(135deg, var(--lg-primary), var(--lg-secondary));
        box-shadow: 0 10px 22px rgba(8, 124, 143, .22);
    }

        .btn-lymph:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(8, 124, 143, .28);
        }

    .lg-alert {
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, rgba(8,124,143,0.08), rgba(111,189,99,0.12));
        border: 1px solid rgba(111,189,99,0.25);
        color: #2f6f5f;
        border-radius: 16px;
        padding: 12px 14px;
        font-size: 14px;
        font-weight: 500;
    }

    .lg-table {
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        .lg-table thead th {
            border: 0;
            color: #8b95a7;
            font-size: 13px;
            font-weight: 700;
            padding: 0 18px 8px;
        }

        .lg-table tbody tr {
            background: #fff;
            box-shadow: 0 8px 20px rgba(31, 45, 61, .055);
        }

        .lg-table tbody td {
            border: 0;
            padding: 18px;
            vertical-align: middle;
        }

            .lg-table tbody td:first-child {
                border-top-left-radius: 18px;
                border-bottom-left-radius: 18px;
            }

            .lg-table tbody td:last-child {
                border-top-right-radius: 18px;
                border-bottom-right-radius: 18px;
            }

    .notification-icon {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        background: linear-gradient(135deg, rgba(8,124,143,.12), rgba(111,189,99,.18));
        color: var(--lg-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    @@media(max-width: 768px) {
        .lymph-page {
            padding: 24px 16px;
        }

        .lymph-hero {
            padding: 24px;
        }

        .hero-title {
            font-size: 24px;
        }
    }
</style>

<div id="app" class="lymph-page mb-5 mt-1">

    <div class="lymph-hero">
        <div class="d-flex justify-content-between align-items-center position-relative">
            <div>
                <h1 class="hero-title">Bildirimler</h1>
                <p class="hero-subtitle">
                    Kullanıcılara manuel bildirim gönderebilir ve daha önce gönderilen bildirimleri görüntüleyebilirsiniz.
                </p>
            </div>

            <div class="hero-logo-mark d-none d-md-flex">
                <img src="~/logo/logo_1.png" alt="LymphGuide" />
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-xl-4">
            <div class="lg-card h-100">
                <div class="lg-card-header">
                    <h5 class="section-title">
                        <i class="fa fa-bell me-2 text-success"></i>
                        Bildirim Gönder
                    </h5>
                    <p class="section-desc">
                        Kullanıcılara gönderilecek bildirimi yazınız.
                    </p>
                </div>

                <div class="lg-card-body">

                    <div class="lg-alert mb-3">
                        <i class="fa fa-info-circle me-2"></i>
                        Bildirim mesajı zorunludur.
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Bildirim Mesajı</label>
                        <textarea class="form-control lg-input"
                                  rows="6"
                                  v-model="form.message"
                                  placeholder="Bildirim mesajını giriniz..."></textarea>
                    </div>

                    <button class="btn btn-lymph w-100" @@click="sendNotification">
                        <i class="fa fa-paper-plane me-1"></i>
                        Bildirim Gönder
                    </button>

                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="lg-card">
                <div class="lg-card-header">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div>
                            <h5 class="section-title">
                                <i class="fa fa-list me-2 text-info"></i>
                                Bildirim Listesi
                            </h5>
                            <p class="section-desc">
                                Sisteme kaydedilen bildirimleri görüntüleyin.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="lg-card-body">

                    <div class="mb-3">
                        <input class="form-control lg-input"
                               v-model="search"
                               placeholder="Bildirim mesajına göre ara..." />
                    </div>

                    <div class="table-responsive">
                        <table class="table lg-table">
                            <thead>
                                <tr>
                                    <th>Bildirim</th>
                                    <th>Oluşturulma Tarihi</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr v-for="item in filteredNotifications" :key="item.id">
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="notification-icon">
                                                <i class="fa fa-bell"></i>
                                            </div>

                                            <div>
                                                <span class="text-muted">
                                                    {{ item.message }}
                                                </span>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="text-muted">
                                            {{ formatDate(item.createdAt) }}
                                        </span>
                                    </td>
                                </tr>

                                <tr v-if="filteredNotifications.length === 0">
                                    <td colspan="2" class="text-center text-muted py-5">
                                        Bildirim kaydı bulunamadı.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/page-js/notification/index.js"></script>
}