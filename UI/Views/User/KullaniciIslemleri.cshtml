@{
    ViewData["Title"] = "Kullanıcı İşlemleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["Title"] = "Kullanıcı İşlemleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --lg-primary: #087c8f;
        --lg-secondary: #6fbd63;
        --lg-soft: #eef9f5;
        --lg-dark: #2f3a4a;
        --lg-muted: #8b95a7;
    }

    .lymph-page {
        min-height: calc(100vh - 140px);
    }

    .lymph-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 32px;
        margin-bottom: 28px;
        background: linear-gradient(135deg, #087c8f 0%, #28a49a 48%, #6fbd63 100%);
        color: #fff;
        box-shadow: 0 18px 45px rgba(8, 124, 143, .22);
    }

        .lymph-hero::after {
            content: "";
            position: absolute;
            right: -70px;
            top: -80px;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(255, 255, 255, .16);
        }

    .hero-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .hero-subtitle {
        opacity: .92;
        max-width: 620px;
        margin-bottom: 0;
    }

    .hero-logo-mark {
        width: 86px;
        height: 86px;
        border-radius: 24px;
        background: rgba(255, 255, 255, .95);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 30px rgba(0, 0, 0, .12);
    }

        .hero-logo-mark img {
            width: 68px;
            height: 68px;
            object-fit: contain;
        }

    .lg-card {
        border: 0;
        border-radius: 26px;
        background: rgba(255, 255, 255, .92);
        box-shadow: 0 14px 35px rgba(31, 45, 61, .08);
    }

    .lg-card-header {
        padding: 24px 26px 0;
    }

    .lg-card-body {
        padding: 24px 26px 26px;
    }

    .section-title {
        color: var(--lg-dark);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .section-desc {
        color: var(--lg-muted);
        font-size: 14px;
        margin-bottom: 0;
    }

    .lg-input,
    .lg-select {
        border-radius: 16px;
        border: 1px solid #e4eaf1;
        padding: 12px 15px;
        background-color: #fbfdff;
    }

        .lg-input:focus,
        .lg-select:focus {
            border-color: var(--lg-primary);
            box-shadow: 0 0 0 .18rem rgba(8, 124, 143, .12);
        }

    .btn-lymph {
        border: 0;
        border-radius: 999px;
        padding: 11px 24px;
        color: #fff;
        font-weight: 600;
        background: linear-gradient(135deg, var(--lg-primary), var(--lg-secondary));
        box-shadow: 0 10px 22px rgba(8, 124, 143, .22);
    }

        .btn-lymph:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(8, 124, 143, .28);
        }

    .filter-chip {
        border: 1px solid #dfe8ef;
        background: #fff;
        border-radius: 999px;
        padding: 9px 16px;
        color: #637083;
        font-weight: 500;
    }

        .filter-chip.active {
            color: #fff;
            border-color: transparent;
            background: linear-gradient(135deg, var(--lg-primary), var(--lg-secondary));
        }

    .lg-table {
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        .lg-table thead th {
            border: 0;
            color: #8b95a7;
            font-size: 13px;
            font-weight: 700;
            padding: 0 18px 8px;
        }

        .lg-table tbody tr {
            background: #fff;
            box-shadow: 0 8px 20px rgba(31, 45, 61, .055);
        }

        .lg-table tbody td {
            border: 0;
            padding: 18px;
            vertical-align: middle;
        }

            .lg-table tbody td:first-child {
                border-top-left-radius: 18px;
                border-bottom-left-radius: 18px;
            }

            .lg-table tbody td:last-child {
                border-top-right-radius: 18px;
                border-bottom-right-radius: 18px;
            }

    .user-avatar {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        background: linear-gradient(135deg, rgba(8,124,143,.12), rgba(111,189,99,.18));
        color: var(--lg-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .role-badge {
        border-radius: 999px;
        padding: 8px 13px;
        background: var(--lg-soft);
        color: var(--lg-primary);
        font-weight: 700;
        font-size: 13px;
    }

    .status-ok {
        color: #229b60;
        background: #eaf8f0;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
    }

    .status-no {
        color: #cf3d3d;
        background: #fff0f0;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
    }

    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 13px;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #667085;
        margin-left: 4px;
    }

        .action-btn:hover {
            background: var(--lg-soft);
            color: var(--lg-primary);
        }

    @@media(max-width: 768px) {
        .lymph-page {
            padding: 24px 16px;
        }

        .lymph-hero {
            padding: 24px;
        }

        .hero-title {
            font-size: 24px;
        }
    }

    .lg-alert {
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, rgba(8,124,143,0.08), rgba(111,189,99,0.12));
        border: 1px solid rgba(111,189,99,0.25);
        color: #2f6f5f;
        border-radius: 16px;
        padding: 12px 14px;
        font-size: 14px;
        font-weight: 500;
    }

    .btn-sm {
        font-size: 12px;
        padding: 6px 12px;
    }

    .btn i {
        font-size: 12px;
    }

    .user-action-buttons {
        display: flex !important;
        flex-direction: column !important;
        align-items: flex-end !important;
    }

    .action-row {
        display: flex !important;
        gap: 8px !important;
        justify-content: flex-end !important;
        flex-wrap: nowrap !important;
    }

        .action-row .btn,
        .action-row a.btn {
            min-width: 115px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
        }
</style>

<div id="app" class="lymph-page mb-5 mt-1">

    <div class="lymph-hero">
        <div class="d-flex justify-content-between align-items-center position-relative">
            <div>
                <h1 class="hero-title">Kullanıcı İşlemleri</h1>
                <p class="hero-subtitle">
                    LymphGuide panelindeki admin ve kullanıcı hesaplarını buradan yönetebilir,
                    şifre sıfırlama ve detay işlemlerini hızlıca yapabilirsiniz.
                </p>
            </div>

            <div class="hero-logo-mark d-none d-md-flex">
                <img src="~/logo/logo_1.png" alt="LymphGuide" height="150" />
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-xl-12">
            <div class="lg-card h-100">
                <div class="lg-card-header">
                    <h5 class="section-title">
                        <i class="fa fa-user-plus me-2 text-success"></i>
                        Yeni Kullanıcı
                    </h5>
                    <p class="section-desc">Admin veya kullanıcı rolüyle yeni kayıt oluşturun.</p>
                </div>

                <div class="lg-card-body">

                    <div class="lg-alert mb-3">
                        <i class="fa fa-info-circle me-2"></i>
                        Kullanıcı şifresi otomatik olarak '123123Aa' olarak oluşturulacaktır.
                    </div>
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="mb-3">
                                <label class="form-label">Ad Soyad</label>
                                <input class="form-control lg-input"
                                       v-model="form.fullName"
                                       placeholder="Ad Soyad" />
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="mb-3">
                                <label class="form-label">Telefon Numarası</label>
                                <input class="form-control lg-input"
                                       v-model="form.phone"
                                       @@input="formatPhone"
                                       placeholder="5XXXXXXXXX" />
                            </div>
                        </div>
                        
                    </div>
                  

                    @* <div class="mb-3">
                        <label class="form-label">Şifre</label>
                        <input type="password"
                               class="form-control lg-input"
                               v-model="form.password"
                               placeholder="Geçici şifre" />
                    </div> *@

                    <div class="mb-4">
                        <label class="form-label">Rol</label>
                        <select class="form-select lg-select" v-model="form.roleId">
                            <option value="">Rol seçiniz</option>
                            <option v-for="role in roles" :value="role.id">
                                {{ role.name }}
                            </option>
                        </select>
                    </div>

                    <button class="btn btn-lymph w-100" @@click="saveUser">
                        <i class="fa fa-check-circle me-1"></i>
                        {{ form.id ? 'Kullanıcıyı Güncelle' : 'Kullanıcı Oluştur' }}
                    </button>

                    <button v-if="form.id"
                            class="btn btn-light w-100 rounded-pill mt-2"
                            @@click="clearForm">
                        Vazgeç
                    </button>
                </div>
            </div>
        </div>

        <div class="col-xl-12">
            <div class="lg-card">
                <div class="lg-card-header">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div>
                            <h5 class="section-title">
                                <i class="fa fa-users me-2 text-info"></i>
                                Kullanıcı Listesi
                            </h5>
                            <p class="section-desc">Filtreleyin, düzenleyin veya detaylara geçin.</p>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="filter-chip"
                                    :class="{ active: filters.roleId === '' }"
                                    @@click="filters.roleId = ''">
                                Tümü
                            </button>

                            <button class="filter-chip"
                                    v-for="role in roles"
                                    :class="{ active: filters.roleId == role.id }"
                                    @@click="filters.roleId = role.id">
                                {{ role.name }}
                            </button>
                        </div>
                    </div>
                </div>

                <div class="lg-card-body">
                    <div class="mb-3">
                        <input class="form-control lg-input"
                               v-model="filters.search"
                               placeholder="Telefon veya rol adına göre ara..." />
                    </div>

                    <div class="table-responsive">
                        <table class="table lg-table">
                            <thead>
                                <tr>
                                    <th>Kullanıcı</th>
                                    <th>Rol</th>
                                    <th>KVKK</th>
                                    <th>Onam</th>
                                    <th>İlk Giriş</th>
                                    <th class="text-end">İşlemler</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr v-for="user in filteredUsers" :key="user.id">
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                           
                                            <div>
                                                <div class="fw-bold text-dark">{{ formatDisplayPhone(user.phone) }}</div>
                                                <small>{{user.fullName}}</small>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="role-badge">{{ user.roleName }}</span>
                                    </td>

                                    <td>
                                        <span v-if="isAdmin(user)" class="text-muted">—</span>
                                        <span v-else :class="user.kvkkApproved ? 'status-ok' : 'status-no'">
                                            {{ user.kvkkApproved ? 'Onaylı' : 'Bekliyor' }}
                                        </span>
                                    </td>

                                    <td>
                                        <span v-if="isAdmin(user)" class="text-muted">—</span>
                                        <span v-else :class="user.onamApproved ? 'status-ok' : 'status-no'">
                                            {{ user.onamApproved ? 'Onaylı' : 'Bekliyor' }}
                                        </span>
                                    </td>

                                    <td>
                                        <span v-if="isAdmin(user)" class="text-muted">—</span>
                                        <span v-else :class="user.ilkGiris ? 'status-no' : 'status-ok'">
                                            {{ user.ilkGiris ? 'Evet' : 'Hayır' }}
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <div class="user-action-buttons">

                                            <!-- 1. SATIR -->
                                            <div class="action-row">

                                                <a v-if="user.roleName === 'Kullanıcı'"
                                                   @@click="goDetail(user.id)"
                                                   class="btn btn-sm btn-info rounded-pill">
                                                    <i class="fa fa-eye me-1"></i>
                                                    Detay
                                                </a>



                                                <a v-if="user.roleName === 'Kullanıcı'"
                                                   :href="`/Form/Index?userId=${user.id}`"
                                                   class="btn btn-sm btn-success rounded-pill">
                                                    <i class="fa fa-clipboard-list me-1"></i>
                                                    Formlar
                                                </a>

                                                <a v-if="user.roleName === 'Kullanıcı'"
                                                   :href="`/egzersiz_detaylari?userId=${user.id}`"
                                                   class="btn btn-sm btn-success rounded-pill">
                                                    <i class="fa fa-clipboard-list me-1"></i>
                                                    Egzersiz
                                                </a>

                                                <a v-if="user.roleName === 'Kullanıcı'"
                                                   :href="`/masaj_detaylari?userId=${user.id}`"
                                                   class="btn btn-sm btn-success rounded-pill">
                                                    <i class="fa fa-spa me-1"></i>
                                                    Masaj
                                                </a>

                                            </div>

                                            <!-- 2. SATIR -->
                                            <div class="action-row mt-2">

                                                <button class="btn btn-sm btn-light rounded-pill"
                                                        @@click="editUser(user)">
                                                    <i class="fa fa-pen me-1"></i>
                                                    Düzenle
                                                </button>

                                                <button class="btn btn-sm btn-warning text-white rounded-pill"
                                                        @@click="openPasswordModal(user)">
                                                    <i class="fa fa-key me-1"></i>
                                                    Şifre
                                                </button>

                                                <button class="btn btn-sm btn-danger rounded-pill"
                                                        @@click="deleteUser(user.id)">
                                                    <i class="fa fa-trash me-1"></i>
                                                    Sil
                                                </button>

                                            </div>

                                        </div>
                                    </td>
                                </tr>

                                <tr v-if="filteredUsers.length === 0">
                                    <td colspan="6" class="text-center text-muted py-5">
                                        Kullanıcı kaydı bulunamadı.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>


@section Scripts {
    <script src="~/page-js/user/kullanici_islemleri.js"></script>
}